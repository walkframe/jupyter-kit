{
  "name": "jupyter-kit-workspace",
  "private": true,
  "version": "3.0.0-rc.4",
  "description": "Monorepo for @jupyter-kit packages (core, react, vue, wc, plugins, executors, themes).",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "build:all": "pnpm run build && pnpm run storybook:build",
    "rebuild": "pnpm run clean && pnpm run build",
    "clean": "pnpm -r --filter './packages/*' run clean",
    "typecheck": "pnpm -r --filter './packages/*' run typecheck",
    "test": "pnpm --filter './packages/*' --filter '!@jupyter-kit/e2e' run --if-present test",
    "test:e2e": "pnpm --filter @jupyter-kit/e2e test",
    "prettier": "prettier --write \"packages/**/*.{ts,tsx,css,less}\"",
    "eslint": "eslint --ext .ts,.tsx packages",
    "storybook": "pnpm --filter @jupyter-kit/storybook storybook",
    "storybook:build": "pnpm --filter @jupyter-kit/storybook build:static",
    "release": "./scripts/release-all.sh",
    "tag": "./scripts/tag-all.sh",
    "tag:push": "./scripts/tag-all.sh --push",
    "untag": "./scripts/untag-all.sh",
    "untag:remote": "./scripts/untag-all.sh --remote"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "prettier": "^3.2.5",
    "tsup": "^8.3.0",
    "typescript": "^5.4.2"
  },
  "packageManager": "pnpm@10.33.0",
  "author": "righ",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/walkframe/jupyter-kit.git"
  },
  "homepage": "https://jupyter-kit.walkframe.com"
}
