{
  "name": "@jupyter-kit/comm",
  "version": "3.0.0-rc.0",
  "description": "Jupyter Comm protocol interface for @jupyter-kit. Defines the CommProvider + Comm types that executors implement and plugins (notably @jupyter-kit/widgets) consume.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "author": "righ",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/walkframe/jupyter-kit.git",
    "directory": "packages/comm"
  },
  "homepage": "https://jupyter-kit.walkframe.com"
}
