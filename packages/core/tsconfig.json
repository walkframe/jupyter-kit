{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@jupyter-kit/core/jsx-runtime": ["./src/jsx-runtime.ts"],
      "@jupyter-kit/core/jsx-dev-runtime": ["./src/jsx-dev-runtime.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/**/__tests__/**"]
}
