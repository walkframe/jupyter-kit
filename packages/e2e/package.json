{
  "name": "@jupyter-kit/e2e",
  "version": "0.0.0",
  "private": true,
  "description": "Playwright end-to-end tests targeting @jupyter-kit/storybook.",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "install:browsers": "playwright install chromium",
    "storybook:build": "pnpm --filter @jupyter-kit/storybook build:static",
    "clean": "rm -rf playwright-report test-results"
  },
  "devDependencies": {
    "@jupyter-kit/storybook": "workspace:*",
    "@playwright/test": "^1.48.0",
    "serve": "^14.2.4"
  }
}
