{
  "name": "@jupyter-kit/editor-codemirror",
  "version": "3.0.0-rc.8",
  "description": "CodeMirror 6 based inline editor plugin for @jupyter-kit/core. Lazy-loadable — not pulled in when read-only.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@jupyter-kit/core": "workspace:*"
  },
  "dependencies": {
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/language": "^6.10.2",
    "@codemirror/legacy-modes": "^6.4.0",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.28.0",
    "@lezer/highlight": "^1.2.1"
  },
  "devDependencies": {
    "@jupyter-kit/core": "workspace:*"
  },
  "author": "righ",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/walkframe/jupyter-kit.git",
    "directory": "packages/editor-codemirror"
  },
  "homepage": "https://jupyter-kit.walkframe.com/reference/editor-codemirror/"
}
