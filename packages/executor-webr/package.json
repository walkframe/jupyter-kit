{
  "name": "@jupyter-kit/executor-webr",
  "version": "3.0.0-rc.5",
  "description": "In-browser R executor for @jupyter-kit. Wraps WebR (https://webr.r-wasm.org), which runs R compiled to WebAssembly inside a worker.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@jupyter-kit/core": "workspace:*"
  },
  "dependencies": {
    "@jupyter-kit/editor-codemirror": "workspace:*",
    "webr": "^0.5.9"
  },
  "devDependencies": {
    "@jupyter-kit/core": "workspace:*"
  },
  "author": "righ",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/walkframe/jupyter-kit.git",
    "directory": "packages/executor-webr"
  },
  "homepage": "https://jupyter-kit.walkframe.com"
}
