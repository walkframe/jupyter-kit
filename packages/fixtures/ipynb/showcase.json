    {
      "cell_type": "code",
      "execution_count": 5,
      "metadata": {},
      "source": [
        "import sympy\n",
        "sympy.init_printing()\n",
        "x, y = sympy.symbols('x y')\n",
        "(\n",
        "    sympy.sin(x) ** 2 + sympy.cos(x) ** 2,\n",
        "    sympy.Integral(x ** 2, (x, 0, 1)),\n",
        "    sympy.Matrix([[1, 2], [3, 4]]),\n",
        ")"
      ],
      "outputs": [
        {
          "output_type": "execute_result",
          "execution_count": 5,
          "data": {
            "text/latex": [
              "$\\displaystyle \\left( \\sin^{2}{\\left(x \\right)} + \\cos^{2}{\\left(x \\right)}, \\  \\int\\limits_{0}^{1} x^{2}\\, dx, \\  \\left[\\begin{matrix}1 & 2\\\\3 & 4\\end{matrix}\\right]\\right)$"
            ],
            "text/plain": [
              "⎛                   1                        ⎞\n⎜   2         2     ⌠        ⎡1  2⎤⎟\n⎜sin (x) + cos (x), ⎮  x²  dx, ⎢    ⎥⎟\n⎜                   ⌡        ⎣3  4⎦⎟\n⎝                   0                        ⎠"
            ]
          },
          "metadata": {}
        }
      ]
    },
    {
      "cell_type": "code",
