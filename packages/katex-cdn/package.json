{
  "name": "@jupyter-kit/katex-cdn",
  "version": "3.0.0-rc.4",
  "description": "KaTeX via CDN loader for @jupyter-kit/core. Tiny bundle; KaTeX auto-render runs in the browser.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@jupyter-kit/core": "workspace:*"
  },
  "dependencies": {
    "remark-math": "^6.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@jupyter-kit/core": "workspace:*"
  },
  "author": "righ",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/walkframe/jupyter-kit.git",
    "directory": "packages/katex-cdn"
  },
  "homepage": "https://jupyter-kit.walkframe.com"
}
