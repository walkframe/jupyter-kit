{
  "name": "@jupyter-kit/react",
  "version": "3.0.0-rc.7",
  "description": "React wrapper around @jupyter-kit/core.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@jupyter-kit/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=16.9.0",
    "react-dom": ">=16.9.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.24",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "author": "righ",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/walkframe/jupyter-kit.git",
    "directory": "packages/react"
  },
  "homepage": "https://jupyter-kit.walkframe.com"
}
