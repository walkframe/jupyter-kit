{
  "name": "@jupyter-kit/wc",
  "version": "3.0.0-rc.0",
  "description": "Web Component wrapper for @jupyter-kit/core. Defines <jk-notebook> as a CustomElement, usable from any framework or plain HTML.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@jupyter-kit/core": "workspace:*"
  },
  "author": "righ",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/righ/react-ipynb-renderer.git",
    "directory": "packages/wc"
  }
}
